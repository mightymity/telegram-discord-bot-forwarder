# ───────────────────────── Server ─────────────────────────
NODE_ENV=development
PORT=3000
# Public base URL of the dashboard (used for cookie settings in prod)
PUBLIC_URL=http://localhost:3000

# ──────────────────────── Database ────────────────────────
# Local dev (SQLite file relative to apps/server)
DATABASE_URL=file:./prisma/dev.db
# In Docker this is overridden to a mounted volume, e.g. file:/data/forwarder.db

# ─────────────────────── Dashboard auth ───────────────────
# Initial admin account, created on first boot if no admin exists.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-please
# Secret used to sign session cookies / JWT. Use a long random string.
SESSION_SECRET=replace-with-a-long-random-secret-at-least-32-chars

# ──────────────────── Telegram (GramJS / MTProto) ─────────
# Get api_id and api_hash from https://my.telegram.org -> API development tools
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
# Produced by `npm run telegram:login`. Long string. Keep secret.
TELEGRAM_SESSION=

# ──────────────────── Forwarding behavior ────────────────
# Max attempts before a message is marked FAILED
FORWARD_MAX_ATTEMPTS=5
# Discord webhook requests per minute (per webhook). Discord allows ~30/min.
DISCORD_RATE_PER_MIN=25
# Max image size (MB) to re-upload to Discord. Larger images are skipped.
DISCORD_MAX_UPLOAD_MB=8
