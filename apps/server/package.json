{
  "name": "@forwarder/server",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "main": "src/index.ts",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "telegram:login": "tsx src/telegram/login.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "tsx src/db/ensure-sqlite.ts && prisma migrate dev",
    "prisma:deploy": "tsx src/db/ensure-sqlite.ts && prisma migrate deploy",
    "db:seed": "tsx src/db/seed.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/jwt": "^10.1.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/static": "^9.1.3",
    "@prisma/adapter-better-sqlite3": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.10.0",
    "bottleneck": "^2.19.5",
    "dotenv": "^17.4.2",
    "fastify": "^5.8.5",
    "telegram": "^2.26.22",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.9.1",
    "pino-pretty": "^13.1.3",
    "prisma": "^7.8.0",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  }
}
