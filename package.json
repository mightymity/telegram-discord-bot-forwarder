{
  "name": "telegram-discord-forwarder",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "concurrently -n server,web -c blue,magenta \"npm:dev:server\" \"npm:dev:web\"",
    "dev:server": "npm --workspace @forwarder/server run dev",
    "dev:web": "npm --workspace @forwarder/web run dev",
    "build": "npm --workspace @forwarder/web run build",
    "start": "npm --workspace @forwarder/server run start",
    "telegram:login": "npm --workspace @forwarder/server run telegram:login",
    "prisma:generate": "npm --workspace @forwarder/server run prisma:generate",
    "prisma:migrate": "npm --workspace @forwarder/server run prisma:migrate",
    "prisma:deploy": "npm --workspace @forwarder/server run prisma:deploy",
    "db:seed": "npm --workspace @forwarder/server run db:seed",
    "test": "npm --workspace @forwarder/server run test",
    "desktop:build": "npm run prisma:generate && npm run build && npm --workspace @forwarder/desktop run build",
    "desktop:rebuild-native": "npm --workspace @forwarder/desktop run rebuild-native",
    "desktop:start": "npm --workspace @forwarder/desktop run start",
    "desktop:dist": "npm run desktop:build && npm --workspace @forwarder/desktop run dist",
    "desktop:dist:mac": "npm run desktop:build && npm --workspace @forwarder/desktop run dist:mac",
    "desktop:dist:win": "npm run desktop:build && npm --workspace @forwarder/desktop run dist:win"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  },
  "engines": {
    "node": ">=20"
  }
}
